---
---

<starlight-theme-select>
  <button type="button" aria-label={Astro.locals.t('themeSelect.accessibleLabel')} class="theme-toggle">
    <svg class="icon sun" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="5" />
      <line x1="12" y1="1" x2="12" y2="3" />
      <line x1="12" y1="21" x2="12" y2="23" />
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
      <line x1="1" y1="12" x2="3" y2="12" />
      <line x1="21" y1="12" x2="23" y2="12" />
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
    </svg>
    <svg class="icon moon" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
  </button>
</starlight-theme-select>

{/* Inlined to avoid FOUC. Uses global scope from ThemeProvider.astro */}
<script is:inline>
  StarlightThemeProvider.updatePickers();
</script>

<script>
  type Theme = 'dark' | 'light';

  const storageKey = 'starlight-theme';

  const parseTheme = (theme: unknown): Theme =>
    theme === 'light' ? 'light' : 'dark';

  const loadTheme = (): Theme =>
    parseTheme(typeof localStorage !== 'undefined' && localStorage.getItem(storageKey));

  function storeTheme(theme: Theme): void {
    if (typeof localStorage !== 'undefined') {
      localStorage.setItem(storageKey, theme);
    }
  }

  function onThemeChange(theme: Theme): void {
    document.documentElement.dataset.theme = theme;
    storeTheme(theme);
  }

  class StarlightThemeSelect extends HTMLElement {
    constructor() {
      super();
      onThemeChange(loadTheme());
      this.querySelector('button')?.addEventListener('click', () => {
        const current = document.documentElement.dataset.theme;
        onThemeChange(current === 'dark' ? 'light' : 'dark');
      });
    }
  }
  customElements.define('starlight-theme-select', StarlightThemeSelect);
</script>

<style>
  @layer starlight.core {
    .theme-toggle {
      background: none;
      border: none;
      cursor: pointer;
      color: var(--sl-color-text-accent);
      padding: 0.5em;
      margin: -0.5em;
      display: flex;
      align-items: center;
    }
    .theme-toggle:hover {
      color: var(--sl-color-white);
    }
    :root[data-theme='dark'] .sun { display: none; }
    :root[data-theme='dark'] .moon { display: block; }
    :root[data-theme='light'] .sun { display: block; }
    :root[data-theme='light'] .moon { display: none; }
    /* Default before JS runs */
    .moon { display: none; }
  }
</style>
