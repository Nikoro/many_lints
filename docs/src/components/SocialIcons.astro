---
const internalLinks = [
  { label: 'Docs', href: '/many_lints/docs/' },
];

const externalLinks = [
  { label: 'GitHub', href: 'https://github.com/Nikoro/many_lints' },
  { label: 'pub.dev', href: 'https://pub.dev/packages/many_lints' },
];
---

{internalLinks.map(({ label, href }) => (
  <a {href} class="social-link sl-flex">
    <span>{label}</span>
  </a>
))}

{externalLinks.map(({ label, href }) => (
  <a {href} target="_blank" rel="noopener noreferrer" class="social-link sl-flex">
    <span>{label}</span>
    <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
      <polyline points="15 3 21 3 21 9" />
      <line x1="10" y1="14" x2="21" y2="3" />
    </svg>
  </a>
))}

<style>
  @layer starlight.core {
    .social-link {
      color: var(--sl-color-text-accent);
      text-decoration: none;
      align-items: center;
      gap: 0.25em;
      font-size: var(--sl-text-sm);
    }
    .social-link:hover {
      color: var(--sl-color-white);
    }
  }
</style>
